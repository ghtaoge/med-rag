# Med-Rag 环境变量配置
# 优先级：环境变量 > config.yaml > 默认值

RAG_MILVUS_HOST=localhost
RAG_MILVUS_PORT=19530
RAG_REDIS_HOST=localhost
RAG_REDIS_PORT=6379
RAG_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
QWEN_API_KEY=
ZHIPU_API_KEY=

RAG_CORS_ORIGINS=http://localhost:3000
RAG_DATABASE_URL=sqlite:///./data/med_rag.db
RAG_JWT_SECRET=
RAG_SECURE_COOKIES=true
POSTGRES_PASSWORD=
RAG_INITIAL_ADMIN_USERNAME=admin
RAG_INITIAL_ADMIN_PASSWORD=
RAG_INITIAL_ADMIN_DEPARTMENT=平台管理
RAG_LOG_LEVEL=INFO
RAG_ENVIRONMENT=development
